<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <Sequence>

        <Action ID="InitReceptionist" cam_frame="{cam_frame}"
                                    manipulation_frame="{man_frame}"
                                    host_name="{h_name}"
                                    host_drink="{h_drink}"
                                    current_guest="{n}"
                                    attention_home="{attention_home}" /> 
                                
        <Action ID="Speak" say_text="come here"/>
        <Action ID="GetAttendedGuest" guest_attended="{guest_attending}"/>
        <Action ID="RemoveStringPrefix" string_to_remove="{guest_attending}" prefix="guest" result="{n}"/>

        <Action ID="Speak" say_text="I'll find you a seat"/>

        <Switch2 variable="{n}"  case_1="1" case_2="2" >

            <Sequence>
                <RetryUntilSuccessful num_attempts="-1">
                    <Fallback>
                        <Timeout msec="30000">
                            <ReactiveFallback>
                                <Condition ID="IsSittable" cam_frame="{cam_frame}" chair_frame="{chair_frame}"/>
                                <Action ID="Pan" period="20.0" range="45" pitch_angle="-5"/>
                            </ReactiveFallback>
                        </Timeout>
                        <Sequence>
                            <Action ID="Explain" question="IsSittable" auto_triggered="true" explanation="{explain_text}"/>
                            <Action ID="Speak" say_text="{explain_text}"/>
                            <AlwaysFailure/>
                        </Sequence>
                    </Fallback>
                </RetryUntilSuccessful>
                <Action ID="LookAt" tf_frame="{chair_frame}"/>
                <!-- <Action ID="PointAt" tf_frame="{chair_frame}" 
                                        base_frame="base_link"
                                        low_z="0.6"
                                        high_z="0.9"/> -->
                <Action ID="Speak" say_text="Please, sit over there"/> 
                <!-- <Delay delay_msec="500">
                    <Action ID="PlayMotionPredefined" motion_name="home"/>
                </Delay> -->
                <Action ID="LookAt" tf_frame="{attention_home}"/>
            </Sequence>

            <Sequence>
                <RetryUntilSuccessful num_attempts="-1">
                    <Fallback>
                        <Timeout msec="30000">
                            <ReactiveFallback>
                                <Condition ID="IsSittable" cam_frame="{cam_frame}" chair_frame="{chair_frame}"/>
                                <Action ID="Pan" period="20.0" range="45" pitch_angle="-5"/>
                            </ReactiveFallback>
                        </Timeout>
                        <Sequence>
                            <Action ID="Explain" question="IsSittable" auto_triggered="true" explanation="{explain_text}"/>
                            <Action ID="Speak" say_text="{explain_text}"/>
                            <AlwaysFailure/>
                        </Sequence>
                    </Fallback>
                </RetryUntilSuccessful>
                <Action ID="LookAt" tf_frame="{chair_frame}"/>
                <Delay delay_msec="1000">
                    <RetryUntilSuccessful num_attempts="4">
                        <Action ID="CheckPolicy" question="<__media__>
                                                        You are a robot helping a guest find a place to sit.

                                                        Look at the image and choose ONE seat that is clearly free.

                                                        Answer with a short natural phrase that completes:
                                                        'So, you can sit at ...'

                                                        Rules:
                                                        - The place must be a real seat (chair, sofa, armchair, bench, stool).
                                                        - Always describe the seat with its position relative to something visible.
                                                        - Use simple spatial relations like:
                                                        'next to', 'near', 'to the left of', 'to the right of'.
                                                        - The answer must include BOTH:
                                                        1) the seat
                                                        2) its relative position

                                                        Restrictions:
                                                        - Do not say only 'the chair' or 'the sofa'.
                                                        - Do not use 'table' as the seat (only as reference).
                                                        - Do not invent objects.
                                                        - Do not use coordinates or special tokens.
                                                        - Output only the phrase, nothing else."
                                                output_text="{description}"
                                                image_topic="/all_perceptions"/>   
                    </RetryUntilSuccessful>
                </Delay>       
                <Action ID="Speak" say_text="" param="{description}"/>
            </Sequence>
            
            <Action ID="Speak" say_text="Please sit where you find yourself more comfortable "/>
            
        </Switch2>
        </Sequence> 

    </BehaviorTree>
</root>