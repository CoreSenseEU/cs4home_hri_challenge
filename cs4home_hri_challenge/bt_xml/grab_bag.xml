<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <Sequence>
            <Action ID="InitReceptionist" cam_frame="{cam_frame}"
                                          manipulation_frame="{man_frame}"
                                          host_name="{h_name}"
                                          host_drink="{h_drink}"
                                          current_guest="{n}"
                                          attention_home="{attention_home}" />

            <RetryUntilSuccessful num_attempts="-1">
                <Condition ID="IsDetected" best_detection="{best_detection}" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
            </RetryUntilSuccessful>
            <Action ID="LookAt" tf_frame="{best_detection}"/> 
            <RetryUntilSuccessful num_attempts="-1">
                <Sequence>
                    <ReactiveSequence>
                        <RetryUntilSuccessful num_attempts="-1">  
                            <Condition ID="IsDetected" best_detection="{best_detection}" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                        </RetryUntilSuccessful>
                        <Action ID="LookAt" tf_frame="{best_detection}"/> 
                        <Action ID="Speak" say_text="So the host" param="{h_name}"/>
                    </ReactiveSequence>
                    <ReactiveSequence>
                        <RetryUntilSuccessful num_attempts="-1">  
                            <Condition ID="IsDetected" best_detection="{best_detection}" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                        </RetryUntilSuccessful>
                        <Action ID="LookAt" tf_frame="{best_detection}"/>
                        <Action ID="Speak" say_text="told me you have something for me"/>
                    </ReactiveSequence>
                    
                    <ReactiveSequence>
                        <RetryUntilSuccessful num_attempts="-1">  
                            <Condition ID="IsDetected" best_detection="{best_detection}" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                        </RetryUntilSuccessful>
                        <Action ID="LookAt" tf_frame="{best_detection}"/>
                        <Action ID="Speak" say_text="Please show it to me"/>
                    </ReactiveSequence>
                </Sequence>
            </RetryUntilSuccessful>

            
            

            <!-- <Delay delay_msec="140">
                <Action ID="MoveToPredefined" pose="open" group_name="gripper"/>
            </Delay>
            <ReactiveSequence>
                <RetryUntilSuccessful num_attempts="-1">
                    <Condition ID="IsDetected" cam_frame="head_front_camera_rgb_optical_frame" confidence="0.6" frames="{frames}" interest="person" max_depth="5" max_entities="1" order="depth"/>
                </RetryUntilSuccessful>
                <Action ID="FilterEntity" frame="person_0" lambda="0.1"/>
                <Action ID="LookAt" tf_frame="person_0_filtered" />
            </ReactiveSequence>
            <Delay delay_msec="140">
                <Action ID="MoveToPredefined" pose="close" group_name="gripper"/>
            </Delay>  -->
        </Sequence> 
    </BehaviorTree>
</root>