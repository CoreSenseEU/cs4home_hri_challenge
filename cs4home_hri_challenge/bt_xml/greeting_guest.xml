<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <Sequence>
            <Action ID="InitReceptionist" cam_frame="{cam_frame}"
                                          manipulation_frame="{man_frame}"
                                          host_name="{h_name}"
                                          host_drink="{h_drink}"
                                          current_guest="{n}"
                                          attention_home="{attention_home}" />
            <Action ID="LookAt" tf_frame="{attention_home}"/> 

            <Action ID="SetHeadJointPosition" horizontal="0.0" vertical="0.0873"/>
            <Action ID="Speak" say_text="I'm ready to receive a new guest, going to the door"/> 
            <!-- <Fallback>
                <Action ID="MoveTo" is_truncated="false" distance_tolerance="-1.0" tf_frame="entrance" will_finish="true"/>
                <Sequence>
                    <Action ID="Explain" question="MoveTo" auto_triggered="true" explanation="{explain_text}"/>
                    <Action ID="Speak" say_text="{explain_text}"/>
                </Sequence>
            </Fallback> -->
            <Action ID="EnableDetectByIdentity" enable="false"/>

            <RetryUntilSuccessful num_attempts="-1">
                <Fallback>
                    <Timeout msec="18000">
                        <ReactiveFallback>                                
                            <Condition ID="IsDetected" confidence="0.6"
                                                        interest="person"
                                                        frames=""
                                                        max_depth="2"
                                                        max_entities="1"
                                                        order="depth_nearest"
                                                        best_detection="{best_detection}"/>
                            <Action ID="Pan" period="20.0" range="45" pitch_angle="-5"/>
                        </ReactiveFallback>
                    </Timeout>
                    <Inverter>
                        <Sequence>
                            <Action ID="Explain" question="IsDetected" auto_triggered="true" explanation="{explain_text}"/>
                            <Action ID="Speak" say_text="{explain_text}"/>
                            <Action ID="Speak" say_text="Could you please come closer?"/>
                        </Sequence>
                    </Inverter>
                    <Delay delay_msec="3000">
                        <AlwaysFailure/>
                    </Delay>
                </Fallback>
            </RetryUntilSuccessful>
            <Action ID="LookAt" tf_frame="{best_detection}"/> 
            <Timeout msec="3000">  <!-- ensure we are looking at the person for a bit -->
                <RetryUntilSuccessful num_attempts="-1">
                    <Sequence>
                        <Action ID="LookAt" tf_frame="{best_detection}"/>
                        <Delay delay_msec="300">
                            <AlwaysSuccess/>
                        </Delay>
                        <Condition ID="IsDetected" confidence="0.6"
                                interest="person" frames=""
                                max_depth="2" max_entities="1"
                                order="depth_nearest"
                                best_detection="{best_detection}"/>
                    </Sequence>
                </RetryUntilSuccessful>
            </Timeout>

            <Action ID="GetAttendedGuest" guest_attended="{guest_attending}"/>
            <Action ID="RemoveStringPrefix" string_to_remove="{guest_attending}" prefix="guest" result="{n}"/>
            <Switch2 variable="{n}"  case_1="0" case_2="1" >
                <Sequence>
                    <RetryUntilSuccessful num_attempts="-1">
                        <Fallback>
                            <Timeout msec="10000">
                                <RetryUntilSuccessful num_attempts="-1">
                                    <ReactiveFallback>
                                        <Action ID="EnableDetectByIdentity" enable="true"/>
                                        <Sequence>
                                            <Action ID="StoreIdentityVector" identity="guestone"/>
                                            <Delay delay_msec="500">
                                                <AlwaysFailure/>
                                            </Delay>
                                        </Sequence>
                                    </ReactiveFallback>
                                </RetryUntilSuccessful>
                            </Timeout>
                            <Inverter>
                                <Action ID="Speak" say_text="I'm having trouble recognizing you, could you please come closer and look at me?"/>
                            </Inverter>
                            <Delay delay_msec="3000">
                                <AlwaysFailure/>
                            </Delay>
                        </Fallback>
                    </RetryUntilSuccessful>
                    <SetBlackboard output_key="guestid" value="guestone"/>
                </Sequence>

                <Sequence>
                    <Action ID="EnableDetectByIdentity" enable="true"/>
                    <RetryUntilSuccessful num_attempts="-1">
                        <ReactiveFallback>
                            <Condition ID="IsDetected" best_detection="{best_detection}"
                                                       confidence="0.6"
                                                       interest="person"
                                                       frames=""
                                                       max_depth="2"
                                                       max_entities="1"
                                                       order="depth_nearest"
                                                       target_identity="guesttwo"/>
                            <Sequence>
                                <Action ID="StoreIdentityVector" identity="guesttwo"/>
                                <Delay delay_msec="500">
                                    <AlwaysFailure/>
                                </Delay>
                            </Sequence>
                        </ReactiveFallback>
                    </RetryUntilSuccessful>
                    <SetBlackboard output_key="guestid" value="guesttwo"/>
                </Sequence>

                <Sequence>
                    <RetryUntilSuccessful num_attempts="-1">
                        <Fallback>
                            <Action ID="StoreIdentityVector" identity="default"/>
                            <Delay delay_msec="500">
                                <AlwaysFailure/>
                            </Delay>
                        </Fallback>
                    </RetryUntilSuccessful>
                    <Action ID="EnableDetectByIdentity" enable="true"/>
                    <SetBlackboard output_key="guestid" value="default"/>
                </Sequence>
            </Switch2>
            <RetryUntilSuccessful num_attempts="-1">
                <Fallback>
                    <Timeout msec="3000">
                        <RetryUntilSuccessful num_attempts="-1">
                            <Fallback>
                                <Condition ID="IsDetected" best_detection="{best_detection}"
                                                        confidence="0.6"
                                                        interest="person"
                                                        frames=""
                                                        max_depth="2"
                                                        max_entities="1"
                                                        order="depth_nearest"
                                                        target_identity="{guestid}"/>
                                <Inverter>                                                
                                    <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                </Inverter>
                            </Fallback>
                        </RetryUntilSuccessful>
                    </Timeout>
                    <Inverter>
                        <Sequence>
                            <Action ID="Explain" question="IsDetected" auto_triggered="true" explanation="{explain_text}"/>
                            <Action ID="Speak" say_text="{explain_text}"/>
                            <Action ID="Speak" say_text="I think I lost your face would you look at me in the eye or come closer?"/>
                        </Sequence>
                    </Inverter>
                    <Delay delay_msec="3000">
                        <AlwaysFailure/>
                    </Delay>
                </Fallback>
            </RetryUntilSuccessful>

            <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> -->
            <Action ID="LookAt" tf_frame="{best_detection}"/> 
            <RetryUntilSuccessful num_attempts="-1">
                    <SequenceStar>
                        <Sequence>
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">
                                    <Fallback>
                                        <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                    confidence="0.6"
                                                                    interest="person"
                                                                    frames=""
                                                                    max_depth="2"
                                                                    max_entities="1"
                                                                    order="depth_nearest"
                                                                    target_identity="{guestid}"/>
                                        <Inverter>
                                            <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                        </Inverter>
                                    </Fallback>  
                                </RetryUntilSuccessful>
                                <Action ID="LookAt" tf_frame="{best_detection}"/> 
                                <Action ID="Speak" say_text="What's your name?"/>
                            </ReactiveSequence>
                            
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Fallback>
                                        <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                    confidence="0.6"
                                                                    interest="person"
                                                                    frames=""
                                                                    max_depth="2"
                                                                    max_entities="1"
                                                                    order="depth_nearest"
                                                                    target_identity="{guestid}"/>
                                        <Inverter>
                                            <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                        </Inverter>
                                    </Fallback>  
                                </RetryUntilSuccessful>
                                <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> -->
                                <Action ID="LookAt" tf_frame="{best_detection}"/> 

                            </ReactiveSequence>
                            
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Fallback>
                                        <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                    confidence="0.6"
                                                                    interest="person"
                                                                    frames=""
                                                                    max_depth="2"
                                                                    max_entities="1"
                                                                    order="depth_nearest"
                                                                    target_identity="{guestid}"/>
                                        <Inverter>
                                            <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                        </Inverter>
                                    </Fallback>
                                </RetryUntilSuccessful>
                                <Action ID="LookAt" tf_frame="{best_detection}"/> 

                                <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> -->
                                <Action ID="Listen" listen_text="{text_value}"/>
                            </ReactiveSequence>
                            
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Fallback>
                                        <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                    confidence="0.6"
                                                                    interest="person"
                                                                    frames=""
                                                                    max_depth="2"
                                                                    max_entities="1"
                                                                    order="depth_nearest"
                                                                    target_identity="{guestid}"/>
                                        <Inverter>
                                            <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                        </Inverter>
                                    </Fallback>
                                </RetryUntilSuccessful>
                                <Action ID="LookAt" tf_frame="{best_detection}"/> 

                                <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>  -->
                                <Action ID="Query" text="{text_value}" intention="name" intention_value="{name_value}"/>
                            </ReactiveSequence>
                        
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Fallback>
                                        <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                    confidence="0.6"
                                                                    interest="person"
                                                                    frames=""
                                                                    max_depth="2"
                                                                    max_entities="1"
                                                                    order="depth_nearest"
                                                                    target_identity="{guestid}"/>
                                        <Inverter>
                                            <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                        </Inverter>
                                    </Fallback>
                                </RetryUntilSuccessful>
                                <Action ID="LookAt" tf_frame="{best_detection}"/> 

                                <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> -->
                                <Action ID="Speak" say_text="So you are" param="{name_value}"/>
                                <Action ID="Speak" say_text="Please say yes or no"/>
                            </ReactiveSequence> 

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Fallback>
                                        <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                    confidence="0.6"
                                                                    interest="person"
                                                                    frames=""
                                                                    max_depth="2"
                                                                    max_entities="1"
                                                                    order="depth_nearest"
                                                                    target_identity="{guestid}"/>
                                        <Inverter>
                                            <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                        </Inverter>
                                    </Fallback>
                                </RetryUntilSuccessful>
                                <Action ID="LookAt" tf_frame="{best_detection}"/> 

                                <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>  -->
                                <Action ID="DialogConfirmation" />
                            </ReactiveSequence>
                        </Sequence>
                        
                        <Sequence>
                            <Action ID="Speak" say_text="What's your favorite drink?"/>
                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Fallback>
                                    <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                confidence="0.6"
                                                                interest="person"
                                                                frames=""
                                                                max_depth="2"
                                                                max_entities="1"
                                                                order="depth_nearest"
                                                                target_identity="{guestid}"/>
                                    <Inverter>
                                        <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                    </Inverter>
                                </Fallback>
                            </RetryUntilSuccessful>
                            <Action ID="LookAt" tf_frame="{best_detection}"/> 

                            <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>  -->
                        </ReactiveSequence>

                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Fallback>
                                    <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                confidence="0.6"
                                                                interest="person"
                                                                frames=""
                                                                max_depth="2"
                                                                max_entities="1"
                                                                order="depth_nearest"
                                                                target_identity="{guestid}"/>
                                    <Inverter>
                                        <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                    </Inverter>
                                </Fallback>
                            </RetryUntilSuccessful>
                            <Action ID="LookAt" tf_frame="{best_detection}"/> 

                            <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>  -->
                            <Action ID="Listen" listen_text="{text_value2}"/>
                        </ReactiveSequence>

                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Fallback>
                                    <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                confidence="0.6"
                                                                interest="person"
                                                                frames=""
                                                                max_depth="2"
                                                                max_entities="1"
                                                                order="depth_nearest"
                                                                target_identity="{guestid}"/>
                                    <Inverter>
                                        <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                    </Inverter>
                                </Fallback>
                            </RetryUntilSuccessful>
                            <Action ID="LookAt" tf_frame="{best_detection}"/> 

                            <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>  -->
                            <Action ID="Query" text="{text_value2}" intention="drink" intention_value="{drink_value}"/>
                        </ReactiveSequence>

                        <Action ID="Speak" say_text="So it seems you like " param="{drink_value}"/>
                        <Action ID="Speak" say_text="Please say yes or no"/>

                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Fallback>
                                    <Condition ID="IsDetected" best_detection="{best_detection}"
                                                                confidence="0.6"
                                                                interest="person"
                                                                frames=""
                                                                max_depth="2"
                                                                max_entities="1"
                                                                order="depth_nearest"
                                                                target_identity="{guestid}"/>
                                    <Inverter>
                                        <Action ID="StoreIdentityVector" identity="{guestid}"/>
                                    </Inverter>
                                </Fallback>
                            </RetryUntilSuccessful>
                            <Action ID="LookAt" tf_frame="{best_detection}"/> 

                            <!-- <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>  -->
                            <Action ID="DialogConfirmation" />
                        </ReactiveSequence>
                        
                        </Sequence>
                    </SequenceStar>
            </RetryUntilSuccessful>
            <Action ID="Speak" say_text="ok, good!"/>
            <!-- <RetryUntilSuccessful num_attempts="-1"> -->
                <Action ID="CheckPolicy" question="<__media__>
                                                    Start the answer with: 'the guest is'.
                                                    Describe the person in one single short natural sentence using only plain text.

                                                    Always include:
                                                    - hair style or hair length,
                                                    - whether the person wears glasses or not,
                                                    - clothing color,
                                                    - and one more visible detail such as accessory, or clothing type.

                                                    Strict rules:
                                                    - Output exactly one brief sentence.
                                                    - Output plain text only.
                                                    - Do not output JSON.
                                                    - Do not output bullet points.
                                                    - Do not output lists.

                                                    Return only the final sentence."
                                    output_text="{description}"
                                    image_topic="/all_perceptions"/>
            <!-- </RetryUntilSuccessful> -->
            <Action ID="Speak" say_text="So, " param="{description}"/>
            <Fallback>
                <Action ID="StoreGuestInfo" guest_name="{name_value}"
                                            guest_description="{description}"
                                            guest_drink="{drink_value}"/>
                <Sequence>
                    <Action ID="RemoveGuestFacts" guest_id="{guest_attending}"/>
                    <Action ID="StoreGuestInfo" guest_name="{name_value}"
                                                guest_description="Friendly and sharp"
                                                guest_drink="{drink_value}"/>
                </Sequence>
            </Fallback>
        </Sequence>
    </BehaviorTree>
</root>