<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <Sequence>
            <Action ID="InitReceptionist" cam_frame="{cam_frame}"
                                          manipulation_frame="{man_frame}"
                                          host_name="{h_name}"
                                          host_drink="{h_drink}"
                                          current_guest="{n}"
                                          attention_home="{attention_home}" />
            <Action ID="LookAt" tf_frame="{attention_home}"/>                                        
            <Action ID="MoveTo" is_truncated="false" distance_tolerance="-1.0" tf_frame="entrance" will_finish="true"/>
            <Action ID="Speak" say_text="Hi, this is Gentlebot. I'm ready to receive a new guest"/>
            <RetryUntilSuccessful num_attempts="-1">
                <Fallback>
                    <Timeout msec="2000">
                        <ReactiveFallback>                                
                            <Condition ID="IsDetected" confidence="0.6"
                                                        interest="person"
                                                        frames=""
                                                        max_depth="2"
                                                        max_entities="1"
                                                        order="depth_nearest"/>
                            <Action ID="Pan" period="20.0" range="45" pitch_angle="10"/>                                    
                        </ReactiveFallback>
                    </Timeout>
                    <Inverter>
                        <Action ID="Speak" say_text="I can't see you, can you please stand in front of me?"/>
                    </Inverter>
                    <Delay delay_msec="3000">
                        <AlwaysFailure/>
                    </Delay>
                </Fallback>
            </RetryUntilSuccessful>
            <RetryUntilSuccessful num_attempts="-1">
                <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
            </RetryUntilSuccessful>
            <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>
            <Action ID="LookAt" tf_frame="person_0_filtered"/> 
            <Action ID="ExtractEntityColor" confidence="0.6" interest="person" person_id="{guest_color_id}"/>
            <RetryUntilSuccessful num_attempts="5">

                <Action ID="CheckPolicy" question="Describe the person in the picture, Please extract 3-5 features. Start the description with 'the guest is...'"
                                    output_text="{description}"
                                    image_topic="/camera/color/image_raw"/>
            </RetryUntilSuccessful>
            <RetryUntilSuccessful num_attempts="-1">
                    <SequenceStar>
                        <Sequence>
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>
                                <Action ID="Speak" say_text="What's your name?"/>
                            </ReactiveSequence>
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>
                            </ReactiveSequence>

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>
                                <Action ID="Listen" listen_text="{text_value}"/>
                            </ReactiveSequence>

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> 
                                <Action ID="Query" text="{text_value}" intention="name" intention_value="{name_value}"/>
                            </ReactiveSequence>
                        
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>
                                <Action ID="Speak" say_text="So you are" param="{name_value}"/>
                                <Action ID="Speak" say_text="Please say yes or no"/>
                            </ReactiveSequence> 

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">  
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> 
                                <Action ID="DialogConfirmation" />
                            </ReactiveSequence>
                        </Sequence>

                        <Sequence>
                            <Action ID="Speak" say_text="What's your favorite drink?"/>
                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                            </RetryUntilSuccessful>
                            <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> 
                        </ReactiveSequence>

                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                            </RetryUntilSuccessful>
                            <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> 
                            <Action ID="Listen" listen_text="{text_value2}"/>
                        </ReactiveSequence>

                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                            </RetryUntilSuccessful>
                            <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> 
                            <Action ID="Query" text="{text_value2}" intention="drink" intention_value="{drink_value}"/>
                        </ReactiveSequence>

                        <Action ID="Speak" say_text="So it seems you like " param="{drink_value}"/>
                        <Action ID="Speak" say_text="Please say yes or no"/>

                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">  
                                <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                            </RetryUntilSuccessful>
                            <Action ID="FilterEntity" frame="person_0" lambda="0.05"/> 
                            <Action ID="DialogConfirmation" />
                        </ReactiveSequence>

                        </Sequence>
                    </SequenceStar>
            </RetryUntilSuccessful>
            <Action ID="StoreDetection" current_name="{name_value}"
                                        guest_description="{description}"
                                        drink="{drink_value}"
                                        guest_id="{n}"
                                        guest_color_id="{guest_color_id}"
                                        name_1="{name_1}"
                                        name_2="{name_2}"
                                        drink_1="{drink_1}"
                                        drink_2="{drink_2}"
                                        guest_color_id_1="{guest_color_id_1}"
                                        guest_color_id_2="{guest_color_id_2}"
                                        guest_description_id_1="{guest_description_id_1}"
                                        guest_description_id_2="{guest_description_id_2}"/>
            <Action ID="Speak" say_text="Please follow me, i will get you to the  party"/>
            <Action ID="LookAt" tf_frame="{attention_home}"/>
        </Sequence>
    </BehaviorTree>
</root>