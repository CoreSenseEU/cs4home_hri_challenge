<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <Sequence>
            <Action ID="InitReceptionist" cam_frame="{cam_frame}"
                                          manipulation_frame="{man_frame}"
                                          host_name="{h_name}"
                                          host_drink="{h_drink}"
                                          current_guest="{n}"
                                          attention_home="{attention_home}" />
            <Sequence>
            <ReactiveFallback>
                <Condition ID="IsDetected" confidence="0.6"
                                            interest="person"
                                            frames="{frames}" 
                                            max_depth="3" 
                                            max_entities="1"
                                            order="depth_nearest"
                                            best_detection="{best_detection}"/>
                            
                <Action ID="Pan" period="45.0" range="45" pitch_angle="-10"/>
            </ReactiveFallback>
            <Action ID="LookAt" tf_frame="{best_detection}"/>
            <Action ID="Speak" say_text="Hi" param="{h_name}"/>
            <Action ID="Speak" say_text=" this is" param="{name_1}"/>
            <Action ID="Speak" say_text=" " param="{guest_description_id_1}"/>
            <Action ID="Speak" say_text=" and their favorite drink is" param="{drink_1}"/>
            <Action ID="MoveTo" is_truncated="false" distance_tolerance="0" tf_frame="guest_confirmation"/>                                
            <ReactiveFallback>
                <Condition ID="IsDetected" confidence="0.6"
                    interest="person"
                    max_depth="1.5" 
                    max_entities="2"
                    person_id="{guest_color_id_1}"
                    order="color"
                    best_detection="{best_detection}"/>

                <Action ID="MoveAlongAxis" 
                                            speed="0.5"
                                            distance="6.28"
                                            axis="z"/>
            </ReactiveFallback>
            <Action ID="LookAt" tf_frame="{best_detection}"/>
            <Action ID="Speak" say_text=" By the way" param="{name_1}"/>
            <Action ID="Speak" say_text="our host" param="{h_name}"/>
            <Action ID="Speak" say_text="enjoys" param="{h_drink}"/>
        </Sequence>
        
        <Sequence>
            <ReactiveFallback>
                <Condition ID="IsDetected" confidence="0.6"
                                                interest="person"
                                                frames="{frames}" 
                                                max_depth="3" 
                                                max_entities="2"
                                                person_id="{host_id}"
                                                order="color"
                                                best_detection="{best_detection}"/>
                <Action ID="Pan" period="30.0" range="45" pitch_angle="-10"/>
            </ReactiveFallback>
            <Action ID="LookAt" tf_frame="{best_detection}"/>

            <Action ID="Speak" say_text="Hi" param="{h_name}"/>
            <Action ID="Speak" say_text=" this is" param="{name_2}"/>
            <Action ID="Speak" say_text=" " param="{guest_description_id_2}"/>                                
            <Action ID="Speak" say_text=" and their favorite drink is" param="{drink_2}"/>
            
            <ReactiveFallback>
                <Condition ID="IsDetected" confidence="0.6"
                                                interest="person"
                                                frames="{frames}" 
                                                max_depth="3" 
                                                max_entities="2"
                                                person_id="{guest_color_id_1}"
                                                order="color"
                                                best_detection="{best_detection}"/>
                <Action ID="Pan" period="20.0" range="45" pitch_angle="-10"/>
            </ReactiveFallback>
            <Action ID="LookAt" tf_frame="{best_detection}"/>

            <Action ID="Speak" say_text="Also we have here with us our guest" param="{name_1}"/>
            <Action ID="Speak" say_text="they like " param="{drink_1}"/>
            <Action ID="MoveTo" is_truncated="false" distance_tolerance="0" tf_frame="guest_confirmation"/>                    

            <ReactiveFallback>
                <Condition ID="IsDetected" confidence="0.6"
                    interest="person"
                    max_depth="1.5" 
                    max_entities="2"
                    person_id="{guest_color_id_2}"
                    order="color"
                    best_detection="{best_detection}"
                    />
                <Action ID="MoveAlongAxis" speed="-0.5" distance="6.28" axis="z"/>
            </ReactiveFallback>
            <Action ID="LookAt" tf_frame="{best_detection}"/>

            <Action ID="Speak" say_text=" By the way" param="{name_2}"/>
            <Action ID="Speak" say_text="our host" param="{h_name}"/>
            <Action ID="Speak" say_text="enjoys" param="{h_drink}"/>
        </Sequence>
        
        <Action ID="Speak" say_text="Hi every one this is our new guest. Please have fun! "/>
        </Sequence> 
    </BehaviorTree>
</root>